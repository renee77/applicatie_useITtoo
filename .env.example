# Kopieer dit bestand naar .env.local en vul jouw eigen waarden in.
# Commit .env.local NOOIT naar git — alleen dit bestand hoort in versiebeheer.

# Database
DB_HOST=localhost          # adres van de databaseserver (lokaal: localhost)
DB_NAME=jouw_database_naam    # naam van de database
DB_USER=root               # databasegebruiker
DB_PASS=                   # wachtwoord van de databasegebruiker
